# Server
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=telemedicina_tfg

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRY=7d

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# CORS
CORS_ORIGIN=http://localhost:4200

# Email / SMTP (Mailtrap sandbox example)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailtrap_username
SMTP_PASS=your_mailtrap_password
SMTP_FROM=no-reply@automed.local
SMTP_CLIENT_NAME=automed.local

# Video Conference (Jitsi/Twilio)
VIDEO_PROVIDER=jitsi
VIDEO_API_KEY=
VIDEO_ROOM_PREFIX=automed-
