<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{{title}}</title>
    <style>
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: "Segoe UI", Arial, sans-serif;
        color: #1a2b3b;
        background: #f5f8fb;
      }
      .page {
        min-height: 297mm;
        padding: 18mm;
        background: #fff;
        border-top: 10px solid #4e9d1d;
      }
      .topbar {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 18px;
        align-items: start;
        padding-bottom: 18px;
        border-bottom: 1px solid #dbeaf8;
      }
      .brand {
        color: #0f4b7a;
        font-size: 18px;
        font-weight: 900;
      }
      h1 {
        margin: 8px 0 0;
        color: #0f4b7a;
        font-size: 28px;
        line-height: 1.15;
      }
      .meta {
        text-align: right;
        color: #5b6673;
        font-size: 11px;
        line-height: 1.7;
      }
      .pill {
        display: inline-block;
        margin-bottom: 8px;
        padding: 5px 10px;
        border-radius: 999px;
        background: #f2faed;
        color: #2e7411;
        font-weight: 800;
      }
      .card {
        margin-top: 18px;
        padding: 14px 16px;
        border: 1px solid #dbeaf8;
        border-radius: 8px;
        background: #fbfdff;
      }
      .section-title {
        margin: 0 0 10px;
        color: #0f4b7a;
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
      }
      .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px 18px;
        font-size: 13px;
      }
      .label {
        color: #667789;
        font-weight: 800;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
        overflow: hidden;
        border-radius: 8px;
      }
      thead {
        background: #eaf6ff;
      }
      th {
        padding: 9px;
        color: #0f4b7a;
        text-align: left;
        border-bottom: 1px solid #cfe4f6;
      }
      td {
        padding: 9px;
        border-bottom: 1px solid #edf2f7;
        vertical-align: top;
      }
      tbody tr:nth-child(even) {
        background: #fbfdff;
      }
      .duration {
        margin-top: 12px;
        padding: 12px;
        border-left: 4px solid #4e9d1d;
        background: #f2faed;
        font-size: 13px;
      }
      .instructions {
        font-size: 13px;
        line-height: 1.8;
      }
      .notice {
        margin-top: 14px;
        padding: 10px 12px;
        border-left: 4px solid #f0b429;
        background: #fff8e6;
        color: #6b5100;
        font-size: 12px;
        font-weight: 700;
      }
      .signature {
        margin-top: 34px;
        padding-top: 18px;
        border-top: 1px solid #dbeaf8;
        display: grid;
        grid-template-columns: 1fr 180px;
        align-items: end;
        gap: 24px;
      }
      .signature-box {
        text-align: center;
      }
      .signature-image {
        height: 58px;
        max-width: 170px;
        object-fit: contain;
        border-bottom: 1px solid #1a2b3b;
      }
      .signature-line {
        height: 58px;
        border-bottom: 1px solid #1a2b3b;
      }
      .signature-name {
        margin-top: 6px;
        font-size: 12px;
        font-weight: 900;
      }
      .signature-date {
        color: #667789;
        font-size: 10px;
      }
      footer {
        margin-top: 28px;
        padding-top: 10px;
        border-top: 1px solid #dbeaf8;
        color: #7a8794;
        font-size: 10px;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <main class="page">
      <header class="topbar">
        <div>
          <div class="brand">AutoMed</div>
          <h1>{{reportType.name}}</h1>
        </div>
        <div class="meta">
          <span class="pill">Plan terapéutico</span><br />
          <strong>ID:</strong>
          #{{id}}<br />
          <strong>Emitido:</strong>
          {{generatedAt}}
        </div>
      </header>

      <section class="card">
        <h2 class="section-title">Datos principales</h2>
        <div class="info-grid">
          <div><span class="label">Paciente:</span> {{patient.name}}</div>
          <div><span class="label">Profesional:</span>
            {{professional.name}}</div>
          <div><span class="label">Categoría:</span>
            {{professional.category}}</div>
        </div>
      </section>

      {{#if metadata.medications}}
        <section class="card">
          <h2 class="section-title">Medicamentos prescritos</h2>
          <table>
            <thead>
              <tr>
                <th>Medicamento</th>
                <th>Dosis</th>
                <th>Frecuencia</th>
                <th>Duración</th>
              </tr>
            </thead>
            <tbody>
              {{#each metadata.medications}}
                <tr>
                  <td>{{this.name}}</td>
                  <td>{{this.dose}}</td>
                  <td>{{this.frequency}}</td>
                  <td>{{this.duration}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </section>
      {{/if}}

      {{#if metadata.duration}}
        <section class="duration">
          <strong>Duración del tratamiento:</strong>
          {{metadata.duration}}
        </section>
      {{/if}}

      <section class="card">
        <h2 class="section-title">Indicaciones del profesional</h2>
        <div class="instructions">{{{body}}}</div>
      </section>

      {{#if metadata.observations}}
        <section class="card">
          <h2 class="section-title">Observaciones</h2>
          <div class="instructions">{{metadata.observations}}</div>
        </section>
      {{/if}}

      <div class="notice">
        Seguir únicamente las indicaciones del profesional sanitario
        responsable.
      </div>

      {{#if signedAt}}
        <section class="signature">
          <div>
            <div class="label">Documento firmado digitalmente</div>
            <div class="signature-date">Fecha de firma: {{signedAt}}</div>
          </div>
          <div class="signature-box">
            {{#if professional.signature}}
              <img
                src="{{professional.signature}}"
                alt="Firma"
                class="signature-image"
              />
            {{else}}
              <div class="signature-line"></div>
            {{/if}}
            <div class="signature-name">{{professional.signatureName}}</div>
          </div>
        </section>
      {{/if}}

      <footer>
        Documento generado por AutoMed. Profesional:
        {{professional.name}}.
      </footer>
    </main>
  </body>
</html>