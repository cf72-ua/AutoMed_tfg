<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Arial", sans-serif;
        line-height: 1.6;
        color: #333;
        background-color: #f5f5f5;
      }

      .container {
        max-width: 210mm;
        height: 297mm;
        margin: 0 auto;
        padding: 20mm;
        background-color: white;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      }

      header {
        text-align: center;
        border-bottom: 2px solid #007bff;
        padding-bottom: 20px;
        margin-bottom: 30px;
      }

      header h1 {
        color: #007bff;
        font-size: 28px;
        margin-bottom: 10px;
      }

      .header-info {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        color: #666;
        margin-top: 10px;
      }

      .patient-section {
        margin-bottom: 25px;
      }

      .section-title {
        font-size: 14px;
        font-weight: bold;
        color: #007bff;
        border-left: 4px solid #007bff;
        padding-left: 10px;
        margin-bottom: 10px;
        margin-top: 15px;
      }

      .patient-info {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        font-size: 13px;
        margin-bottom: 15px;
      }

      .info-row {
        display: flex;
      }

      .info-label {
        font-weight: bold;
        color: #555;
        min-width: 120px;
      }

      .info-value {
        color: #333;
      }

      .content {
        margin: 20px 0;
        font-size: 13px;
        line-height: 1.8;
        text-align: justify;
      }

      .signature-section {
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid #ddd;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
      }

      .signature-block {
        text-align: center;
        width: 150px;
      }

      .signature-image {
        height: 60px;
        margin-bottom: 5px;
        border-bottom: 1px solid #333;
      }

      .signature-name {
        font-size: 12px;
        font-weight: bold;
        margin-top: 5px;
      }

      .signature-date {
        font-size: 11px;
        color: #666;
        margin-top: 3px;
      }

      .footer {
        font-size: 10px;
        color: #999;
        margin-top: 30px;
        text-align: center;
        padding-top: 10px;
        border-top: 1px solid #ddd;
      }

      .stamp {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(-45deg);
        font-size: 48px;
        color: rgba(0, 123, 255, 0.1);
        font-weight: bold;
        text-align: center;
        pointer-events: none;
        z-index: -1;
      }

      @media print {
        body {
          background-color: white;
        }
        .container {
          box-shadow: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <h1>{{reportType.name}}</h1>
        <div class="header-info">
          <span><strong>Fecha de generación:</strong> {{generatedAt}}</span>
          <span><strong>ID Reporte:</strong> #{{id}}</span>
        </div>
      </header>

      <section class="patient-section">
        <div class="section-title">DATOS DEL PACIENTE</div>
        <div class="patient-info">
          <div class="info-row">
            <span class="info-label">Nombre:</span>
            <span class="info-value">{{patient.name}}</span>
          </div>
        </div>
      </section>

      <section>
        <div class="section-title">INFORME MÉDICO</div>
        <div class="content">{{{body}}}</div>
      </section>

      {{#if signedAt}}
        <section class="signature-section">
          <div class="signature-block">
            {{#if professional.signature}}
              <img
                src="{{professional.signature}}"
                alt="Firma"
                class="signature-image"
              />
            {{else}}
              <div class="signature-image"></div>
            {{/if}}
            <div class="signature-name">{{professional.signatureName}}</div>
            <div class="signature-date">Firmado: {{signedAt}}</div>
          </div>
        </section>
      {{/if}}

      <footer class="footer">
        <p>Este documento ha sido generado automáticamente y tiene validez
          legal.</p>
        <p>Profesional: {{professional.name}} ({{professional.category}})</p>
      </footer>
    </div>
  </body>
</html>