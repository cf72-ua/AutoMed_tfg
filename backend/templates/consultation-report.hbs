<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{{title}}</title>
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: "Segoe UI", Arial, sans-serif;
        color: #1a2b3b;
        background: #f5f8fb;
      }
      .page {
        min-height: 297mm;
        padding: 18mm;
        background: #fff;
        border-top: 10px solid #0f4b7a;
      }
      .topbar {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 18px;
        align-items: start;
        padding-bottom: 18px;
        border-bottom: 1px solid #dbeaf8;
      }
      .brand {
        color: #0f4b7a;
        font-size: 18px;
        font-weight: 900;
        letter-spacing: 0;
      }
      h1 {
        margin: 8px 0 0;
        color: #0f4b7a;
        font-size: 28px;
        line-height: 1.15;
      }
      .meta {
        text-align: right;
        color: #5b6673;
        font-size: 11px;
        line-height: 1.7;
      }
      .pill {
        display: inline-block;
        margin-bottom: 8px;
        padding: 5px 10px;
        border-radius: 999px;
        background: #eaf6ff;
        color: #0f4b7a;
        font-weight: 800;
      }
      .card {
        margin-top: 18px;
        padding: 14px 16px;
        border: 1px solid #dbeaf8;
        border-radius: 8px;
        background: #fbfdff;
      }
      .section-title {
        margin: 0 0 10px;
        color: #0f4b7a;
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
      }
      .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px 18px;
        font-size: 13px;
      }
      .label {
        color: #667789;
        font-weight: 800;
      }
      .content {
        margin-top: 18px;
        font-size: 13px;
        line-height: 1.8;
        text-align: justify;
      }
      .summary {
        margin-top: 12px;
        padding: 12px;
        border-left: 4px solid #4e9d1d;
        background: #f2faed;
        font-size: 13px;
      }
      .signature {
        margin-top: 34px;
        padding-top: 18px;
        border-top: 1px solid #dbeaf8;
        display: grid;
        grid-template-columns: 1fr 180px;
        align-items: end;
        gap: 24px;
      }
      .signature-box {
        text-align: center;
      }
      .signature-image {
        height: 58px;
        max-width: 170px;
        object-fit: contain;
        border-bottom: 1px solid #1a2b3b;
      }
      .signature-line {
        height: 58px;
        border-bottom: 1px solid #1a2b3b;
      }
      .signature-name {
        margin-top: 6px;
        font-size: 12px;
        font-weight: 900;
      }
      .signature-date {
        color: #667789;
        font-size: 10px;
      }
      footer {
        margin-top: 28px;
        padding-top: 10px;
        border-top: 1px solid #dbeaf8;
        color: #7a8794;
        font-size: 10px;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <main class="page">
      <header class="topbar">
        <div>
          <div class="brand">AutoMed</div>
          <h1>{{reportType.name}}</h1>
        </div>
        <div class="meta">
          <span class="pill">Informe médico</span><br />
          <strong>ID:</strong> #{{id}}<br />
          <strong>Generado:</strong> {{generatedAt}}
        </div>
      </header>

      <section class="card">
        <h2 class="section-title">Datos principales</h2>
        <div class="info-grid">
          <div><span class="label">Paciente:</span> {{patient.name}}</div>
          <div><span class="label">Profesional:</span> {{professional.name}}</div>
          <div><span class="label">Categoría:</span> {{professional.category}}</div>
          <div><span class="label">Estado:</span> {{status}}</div>
        </div>
      </section>

      {{#if metadata.clinicalSummary}}
        <section class="summary">
          <strong>Resumen clínico:</strong> {{metadata.clinicalSummary}}
        </section>
      {{/if}}

      <section class="card">
        <h2 class="section-title">Contenido del informe</h2>
        <div class="content">{{{body}}}</div>
      </section>

      {{#if metadata.observations}}
        <section class="card">
          <h2 class="section-title">Observaciones</h2>
          <div class="content">{{metadata.observations}}</div>
        </section>
      {{/if}}

      {{#if signedAt}}
        <section class="signature">
          <div>
            <div class="label">Documento firmado digitalmente</div>
            <div class="signature-date">Fecha de firma: {{signedAt}}</div>
          </div>
          <div class="signature-box">
            {{#if professional.signature}}
              <img src="{{professional.signature}}" alt="Firma" class="signature-image" />
            {{else}}
              <div class="signature-line"></div>
            {{/if}}
            <div class="signature-name">{{professional.signatureName}}</div>
          </div>
        </section>
      {{/if}}

      <footer>
        Documento generado por AutoMed. Profesional: {{professional.name}}.
      </footer>
    </main>
  </body>
</html>
